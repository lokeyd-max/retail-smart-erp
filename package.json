{
  "name": "retail-smart-pos-web",
  "version": "1.0.7",
  "private": true,
  "scripts": {
    "dev": "node scripts/build-server.mjs && node scripts/dev-server.mjs",
    "dev:next": "next dev",
    "build": "next build",
    "prebuild": "npm run validate:migrations",
    "postbuild": "node scripts/build-server.mjs",
    "build:server": "node scripts/build-server.mjs",
    "start": "node -e \"console.log('Starting Retail Smart POS...'); if (process.env.SKIP_MIGRATIONS !== 'true') { const { execSync } = require('child_process'); console.log('Running database migrations...'); try { execSync('npm run db:migrate', { stdio: 'inherit' }); console.log('Migrations completed successfully'); } catch(e) { console.error('Migration failed:', e.message); if (process.env.REQUIRE_MIGRATIONS === 'true') { console.error('Migrations required - exiting'); process.exit(1); } else { console.warn('Continuing without migrations (database may already be up to date)...'); } } } process.exit(0);\" && node server.js",
    "start:next": "next start -H 0.0.0.0",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed-admin": "npx tsx scripts/create-super-admin.ts",
    "db:indexes": "npx tsx stress-tests/scripts/apply-indexes.ts",
    "stress:all": "node stress-tests/scripts/run-all-tests.js",
    "stress:quick": "node stress-tests/scripts/run-all-tests.js --quick",
    "stress:http": "k6 run stress-tests/k6/comprehensive-load-test.js",
    "stress:ws": "k6 run stress-tests/k6/websocket-stress-test.js",
    "stress:pos": "k6 run stress-tests/k6/pos-checkout-test.js",
    "stress:spike": "k6 run -e SPIKE_TEST=true stress-tests/k6/pos-checkout-test.js",
    "stress:artillery": "npx artillery run stress-tests/artillery/http-load-test.yml",
    "stress:artillery:ws": "npx artillery run stress-tests/artillery/websocket-load-test.yml",
    "stress:setup-data": "npx tsx stress-tests/scripts/setup-test-data.ts",
    "stress:simple": "node stress-tests/scripts/simple-test.js",
    "validate:migrations": "node scripts/validate-migration-numbers.js",
    "test:e2e": "npx playwright test",
    "test:e2e:smoke": "npx playwright test e2e/tests/smoke/",
    "test:e2e:critical": "npx playwright test e2e/tests/critical/",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:workflows": "npx playwright test --project=workflows",
    "test:e2e:ui-workflows": "npx playwright test --project=ui-workflows",
    "ci": "npm run lint && npm run validate:migrations && npm run build",
    "postinstall": "patch-package && node scripts/patch-next-app-route-context.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@google/generative-ai": "^0.24.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "bcryptjs": "^3.0.3",
    "bwip-js": "^4.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.34.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "mammoth": "^1.11.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "papaparse": "^5.5.3",
    "patch-package": "^8.0.1",
    "pg": "^8.17.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
